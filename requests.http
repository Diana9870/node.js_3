### AUTH

### Register User 1

POST http://localhost:3000/auth/register
Content-Type: application/json

{
"username": "ivan",
"password": "123456",
"name": "Іван"
}

###

### Register User 2

POST http://localhost:3000/auth/register
Content-Type: application/json

{
"username": "petro",
"password": "123456",
"name": "Петро"
}

###

### Login User 1

POST http://localhost:3000/auth/login
Content-Type: application/json

{
"username": "ivan",
"password": "123456"
}

###

### Login User 2

POST http://localhost:3000/auth/login
Content-Type: application/json

{
"username": "petro",
"password": "123456"
}

###

### Current User

GET http://localhost:3000/auth/me
Authorization: Bearer {{accessToken}}

###

### Refresh Token

POST http://localhost:3000/auth/refresh
Content-Type: application/json

{
"refreshToken": "{{refreshToken}}"
}

###

### Logout

POST http://localhost:3000/auth/logout
Authorization: Bearer {{accessToken}}

###

### Invalid Login

POST http://localhost:3000/auth/login
Content-Type: application/json

{
"username": "ivan",
"password": "wrong_password"
}

###

### ANNOUNCEMENTS

### Get All Announcements

GET http://localhost:3000/announcements

###

### Get Announcement By Id

GET http://localhost:3000/announcements/1

###

### Create Announcement

POST http://localhost:3000/announcements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
"title": "iPhone 14",
"description": "Новий смартфон",
"price": 25000,
"category": "electronics",
"contactInfo": "+380991112233"
}

###

### Update Own Announcement

PATCH http://localhost:3000/announcements/1
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
"price": 23000
}

###

### Delete Own Announcement

DELETE http://localhost:3000/announcements/1
Authorization: Bearer {{accessToken}}

###

### Create Without Token (Expected 401)

POST http://localhost:3000/announcements
Content-Type: application/json

{
"title": "Unauthorized",
"description": "Should fail",
"price": 100,
"category": "test",
"contactInfo": "000000000"
}

###

### Update Without Token (Expected 401)

PATCH http://localhost:3000/announcements/1
Content-Type: application/json

{
"price": 1
}

###

### Delete Without Token (Expected 401)

DELETE http://localhost:3000/announcements/1

###

### Ownership Test (Login as User 2 first)

PATCH http://localhost:3000/announcements/1
Authorization: Bearer {{user2AccessToken}}
Content-Type: application/json

{
"price": 999
}

###

### Ownership Delete Test (Expected 403)

DELETE http://localhost:3000/announcements/1
Authorization: Bearer {{user2AccessToken}}
